{
  "name": "gamebot",
  "private": true,
  "type": "module",
  "imports": {
    "#db": "./src/db/index.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "test": "bun test --coverage",
    "format": "oxfmt",
    "lint": "oxlint",
    "dev": "NODE_ENV=development bun run ./src/index.ts",
    "build": "NODE_ENV=production bun build --minify --compile ./src/index.ts --outfile=dist/bot --target=bun-linux-arm64"
  },
  "dependencies": {
    "@grammyjs/runner": "2.0.3",
    "drizzle-orm": "0.45.2",
    "grammy": "1.43.0"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.2",
    "@types/bun": "1.3.14",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "6.0.3"
  }
}
